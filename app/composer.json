{
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-pcntl": "*",
        "binance/binance-connector-php": "v4.0",
        "brick/money": "^0.13.0",
        "composer/package-versions-deprecated": "1.11.99.3",
        "doctrine/doctrine-bundle": "^3.0",
        "doctrine/doctrine-migrations-bundle": "^3.1",
        "doctrine/orm": "^3.4",
        "nelmio/api-doc-bundle": "^5.10",
        "phpdocumentor/reflection-docblock": "^5.3",
        "symfony/asset": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/flex": "^2.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/lock": "^8.0",
        "symfony/messenger": "^8.0",
        "symfony/monolog-bundle": "^4.0",
        "symfony/property-access": "^8.0",
        "symfony/property-info": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/scheduler": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/uid": "^8.0",
        "symfony/validator": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "codeception/codeception": "^5.0",
        "codeception/module-asserts": "^2.0",
        "codeception/module-datafactory": "^3.0",
        "codeception/module-doctrine": "^3.1",
        "codeception/module-symfony": "^3.0",
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "phpstan/extension-installer": "*",
        "phpstan/phpstan": "*",
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "*",
        "symfony/maker-bundle": "^1.33",
        "zenstruck/foundry": "^2.9"
    },

    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php56": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "migration-diff": "bin/console doctrine:migrations:diff --no-interaction",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "update-db": "bin/console doctrine:migrations:migrate --no-interaction",
        "update-db-test": "bin/console doctrine:migrations:migrate --env=test --no-interaction",
        "test": "vendor/bin/codecept run",
        "test-unit": "vendor/bin/codecept run Unit"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8.0"
        }
    }
}
