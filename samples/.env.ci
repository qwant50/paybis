# Sample environment for CI pipelines. There is no docker compose in CI, so the
# pipeline must export these variables itself (e.g. job `env:` / secrets). The test
# suite runs against `${APP_DB}_test` (derived in config/packages/test/doctrine.yaml).
APP_ENV=test
APP_DEBUG=false
APP_SECRET=ci_change_me
APP_DB=app
APP_DB_HOST=127.0.0.1
APP_DB_PORT=3306
APP_DB_USER=app
APP_DB_PASSWORD=app
API_SIGNING_SECRET=test_signing_secret
API_SIGNING_KEY_ID=test
